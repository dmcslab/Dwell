# ─── Dwell Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values before first run.

# REQUIRED — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_32byte_hex_secret

# Database (PostgreSQL — matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://dwell:dwell@db:5432/dwell

# Redis
REDIS_URL=redis://redis:6379/0
# Uncomment to enable Redis authentication (recommended in production):
# REDIS_PASSWORD=CHANGE_ME_redis_password

# Optional flags
# SKIP_SEED_UPDATE=true   # Skip re-seeding scenarios on container restart
# DEBUG=false
