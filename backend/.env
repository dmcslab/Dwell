ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
ORCHESTRATOR_URL=http://orchestrator:9000

APP_BASE_URL=http://localhost:5173
