# Dwell backend configuration
# ─────────────────────────────────────────────────────────────────
# No manual changes needed for basic deployment.
# The SECRET_KEY placeholder is replaced automatically at first start.
# ─────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://dwell:dwell@db:5432/dwell
SYNC_DATABASE_URL=postgresql+psycopg2://dwell:dwell@db:5432/dwell
REDIS_URL=redis://redis:6379/0
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_TOKEN_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_ENV=production
ALLOWED_ORIGINS=*
ORCHESTRATOR_URL=http://orchestrator:9000

# ── Seed behaviour ────────────────────────────────────────────────
# true  (default) → on restart, only INSERT scenarios that don't exist yet.
#                   Scenarios you've edited via the Admin UI are NOT touched.
# false           → INSERT new + UPDATE all existing scenarios from the seed
#                   file. Use this intentionally after pulling a release that
#                   contains updated scenario content, then set back to true.
SKIP_SEED_UPDATE=true
