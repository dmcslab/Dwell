# Copy this to .env and fill in real values
DATABASE_URL=postgresql+asyncpg://cyber:cyber@db:5432/cyberrans
SYNC_DATABASE_URL=postgresql+psycopg2://cyber:cyber@db:5432/cyberrans
REDIS_URL=redis://redis:6379/0
